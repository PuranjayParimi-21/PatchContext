# OpenAI API Key for embeddings and GPT-4o-mini
OPENAI_API_KEY=your_openai_api_key_here

# GitHub Personal Access Token (PAT) for GraphQL and REST APIs (Required for paginated data retrieval)
GITHUB_TOKEN=your_github_token_here

# Local SQLite Database Path
DATABASE_PATH=data/metadata.db

# FAISS Vector Index Directory
VECTORSTORE_PATH=vectorstore

# Repository Details
GITHUB_REPOSITORY=fastapi/fastapi
LOCAL_REPO_PATH=data/fastapi_repo

# NLI Model for Hallucination Guard
NLI_MODEL_NAME=facebook/bart-large-mnli
# Set to True to enable BART NLI validation, False to bypass (for faster local execution without GPU/large model downloads)
ENABLE_NLI_GUARD=true
NLI_ENTAILMENT_THRESHOLD=0.5

# Embedding configuration
EMBEDDING_MODEL=text-embedding-ada-002

# LLM Provider (openai, local, or openrouter)
LLM_PROVIDER=openai
MODEL=gpt-4o-mini

# OpenRouter Configuration (if LLM_PROVIDER=openrouter)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.5-flash
